<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Logo/Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡"
            android:textSize="64sp"
            android:layout_marginTop="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rewards NFC Display"
            android:textColor="#ffffff"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure your BTCPay Server connection"
            android:textColor="#aaaacc"
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="40dp" />

        <!-- BTCPay Server URL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BTCPay Server URL"
            android:textColor="#8888aa"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/input_btcpay_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="https://your-btcpay-server.com"
            android:inputType="textUri"
            android:textColor="#ffffff"
            android:textColorHint="#555577"
            android:background="@android:color/transparent"
            android:padding="16dp"
            android:textSize="18sp"
            android:layout_marginBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333355"
            android:layout_marginTop="-24dp"
            android:layout_marginBottom="24dp" />

        <!-- Store ID -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Store ID"
            android:textColor="#8888aa"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/input_store_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 9TipzyZe9J2RYj..."
            android:inputType="text"
            android:textColor="#ffffff"
            android:textColorHint="#555577"
            android:background="@android:color/transparent"
            android:padding="16dp"
            android:textSize="18sp"
            android:layout_marginBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333355"
            android:layout_marginTop="-24dp"
            android:layout_marginBottom="24dp" />

        <!-- Auto-refresh interval -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto-refresh interval (seconds)"
            android:textColor="#8888aa"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/input_refresh_seconds"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="10"
            android:inputType="number"
            android:textColor="#ffffff"
            android:textColorHint="#555577"
            android:background="@android:color/transparent"
            android:padding="16dp"
            android:textSize="18sp"
            android:layout_marginBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333355"
            android:layout_marginTop="-24dp"
            android:layout_marginBottom="24dp" />

        <!-- NFC Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enable NFC broadcast"
                android:textColor="#ffffff"
                android:textSize="18sp" />

            <Switch
                android:id="@+id/switch_nfc_enabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save &amp; Launch Display"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:background="#4CAF50"
            android:padding="16dp"
            android:layout_marginBottom="40dp" />

    </LinearLayout>
</ScrollView>
